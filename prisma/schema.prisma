generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model Appointment {
  id             Int            @id @default(autoincrement())
  name           String
  phone          String
  email          String?
  service        String
  appointmentAt  DateTime
  notes          String?
  reminderStatus ReminderStatus @default(PENDING)
  reminderSentAt DateTime?
  createdAt      DateTime       @default(now())
}